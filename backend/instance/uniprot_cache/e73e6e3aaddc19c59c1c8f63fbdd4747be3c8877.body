sion":"Q8WZ42","intActId":"EBI-681210"},"interactantTwo":{"uniProtKBAccession":"O15061","geneName":"SYNM","intActId":"EBI-7843148"},"numberOfExperiments":3,"organismDiffer":false},{"interactantOne":{"uniProtKBAccession":"Q8WZ42","intActId":"EBI-681210"},"interactantTwo":{"uniProtKBAccession":"O15273","geneName":"TCAP","intActId":"EBI-954089"},"numberOfExperiments":9,"organismDiffer":false},{"interactantOne":{"uniProtKBAccession":"Q8WZ42","intActId":"EBI-681210"},"interactantTwo":{"uniProtKBAccession":"Q969Q1","geneName":"TRIM63","intActId":"EBI-5661333"},"numberOfExperiments":3,"organismDiffer":false},{"interactantOne":{"uniProtKBAccession":"Q8WZ42","intActId":"EBI-681210"},"interactantTwo":{"uniProtKBAccession":"Q8WZ42","geneName":"TTN","intActId":"EBI-681210"},"numberOfExperiments":16,"organismDiffer":false},{"interactantOne":{"uniProtKBAccession":"Q8WZ42-3","intActId":"EBI-15564183"},"interactantTwo":{"uniProtKBAccession":"O15273","geneName":"TCAP","intActId":"EBI-954089"},"numberOfExperiments":2,"organismDiffer":false},{"interactantOne":{"uniProtKBAccession":"Q8WZ42-3","intActId":"EBI-15564183"},"interactantTwo":{"uniProtKBAccession":"Q8WZ42-3","geneName":"TTN","intActId":"EBI-15564183"},"numberOfExperiments":9,"organismDiffer":false}]},{"commentType":"SUBCELLULAR LOCATION","subcellularLocations":[{"location":{"evidences":[{"evidenceCode":"ECO:0000305","source":"PubMed","id":"16410549"}],"value":"Cytoplasm","id":"SL-0086"}},{"location":{"evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"16410549"}],"value":"Nucleus","id":"SL-0191"}}]},{"commentType":"ALTERNATIVE PRODUCTS","events":["Alternative splicing"],"isoforms":[{"name":{"value":"1"},"isoformIds":["Q8WZ42-1"],"isoformSequenceStatus":"Displayed"},{"name":{"value":"2"},"isoformIds":["Q8WZ42-2"],"sequenceIds":["VSP_019138"],"isoformSequenceStatus":"Described"},{"name":{"value":"3"},"synonyms":[{"value":"Small cardiac N2-B"}],"isoformIds":["Q8WZ42-3"],"sequenceIds":["VSP_019139","VSP_019145"],"isoformSequenceStatus":"Described"},{"name":{"value":"4"},"synonyms":[{"value":"Soleus"}],"isoformIds":["Q8WZ42-4"],"sequenceIds":["VSP_019142","VSP_019151"],"isoformSequenceStatus":"Described"},{"name":{"value":"5"},"isoformIds":["Q8WZ42-5"],"sequenceIds":["VSP_019147","VSP_019148","VSP_019149","VSP_019150","VSP_019152"],"isoformSequenceStatus":"Described"},{"name":{"value":"6"},"synonyms":[{"value":"Small cardiac novex-3"}],"isoformIds":["Q8WZ42-6"],"sequenceIds":["VSP_019143","VSP_019146"],"isoformSequenceStatus":"Described"},{"name":{"value":"7"},"synonyms":[{"value":"Cardiac novex-2"}],"isoformIds":["Q8WZ42-7"],"sequenceIds":["VSP_019141","VSP_019144"],"isoformSequenceStatus":"Described"},{"name":{"value":"8"},"synonyms":[{"value":"Cardiac novex-1"}],"isoformIds":["Q8WZ42-8"],"sequenceIds":["VSP_019140"],"isoformSequenceStatus":"Described"},{"name":{"value":"9"},"isoformIds":["Q8WZ42-9"],"sequenceIds":["VSP_019139","VSP_042903","VSP_019145"],"isoformSequenceStatus":"Described"},{"name":{"value":"10"},"isoformIds":["Q8WZ42-10"],"sequenceIds":["VSP_019139","VSP_019140","VSP_019145"],"isoformSequenceStatus":"Described"},{"name":{"value":"11"},"isoformIds":["Q8WZ42-11"],"sequenceIds":["VSP_019142"],"isoformSequenceStatus":"Described"},{"name":{"value":"12"},"isoformIds":["Q8WZ42-12"],"sequenceIds":["VSP_045935","VSP_045929","VSP_045930","VSP_045931","VSP_045932","VSP_045933","VSP_045934"],"isoformSequenceStatus":"Described"},{"name":{"value":"13"},"isoformIds":["Q8WZ42-13"],"sequenceIds":["VSP_047142"],"isoformSequenceStatus":"Described"}],"note":{"texts":[{"value":"A number of isoforms may be produced, ranging from 27000 to 33000 residues in different striated muscle tissues, the size of the full-length protein may be up to 38138 residues."}]}},{"texts":[{"evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"11717165"},{"evidenceCode":"ECO:0000269","source":"PubMed","id":"7819249"}],"value":"Isoforms 3, 7 and 8 are expressed in cardiac muscle. Isoform 4 is expressed in vertebrate skeletal muscle. Isoform 6 is expressed in skeletal muscle (at protein level)"}],"commentType":"TISSUE SPECIFICITY"},{"texts":[{"value":"ZIS1 and ZIS5 regions contain multiple SPXR consensus sites for ERK- and CDK-like protein kinases as well as multiple SP motifs. ZIS1 could adopt a closed conformation which would block the TCAP-binding site"}],"commentType":"DOMAIN"},{"texts":[{"value":"The PEVK region may serve as an entropic spring of a chain of structural folds and may also be an interaction site to other myofilament proteins to form interfilament connectivity in the sarcomere"}],"commentType":"DOMAIN"},{"texts":[{"evidences":[{"evidenceCode":"ECO:0000250"}],"value":"Autophosphorylated"}],"commentType":"PTM"},{"commentType":"DISEASE","disease":{"diseaseId":"Myopathy, myofibrillar, 9, with early respiratory failure","diseaseAccession":"DI-01727","acronym":"MFM9","description":"An autosomal dominant myopathy characterized by adulthood onset of weakness in proximal, distal, axial and respiratory muscles. Pelvic girdle weakness, foot drop and neck weakness are the main symptoms at onset, but ultimately the weakness usually involves the proximal compartment of both upper and lower limbs. Additional features include variable degrees of Achilles tendon contractures, spinal rigidity and muscle hypertrophy. Respiratory involvement often leads to requirement for non-invasive ventilation support.","diseaseCrossReference":{"database":"MIM","id":"603689"},"evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"15802564"}]},"note":{"texts":[{"value":"The disease is caused by variants affecting the gene represented in this entry"}]}},{"commentType":"DISEASE","disease":{"diseaseId":"Cardiomyopathy, familial hypertrophic, 9","diseaseAccession":"DI-00239","acronym":"CMH9","description":"A hereditary heart disorder characterized by ventricular hypertrophy, which is usually asymmetric and often involves the interventricular septum. The symptoms include dyspnea, syncope, collapse, palpitations, and chest pain. They can be readily provoked by exercise. The disorder has inter- and intrafamilial variability ranging from benign to malignant forms with high risk of cardiac failure and sudden cardiac death.","diseaseCrossReference":{"database":"MIM","id":"613765"},"evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"10462489"}]},"note":{"texts":[{"value":"The disease is caused by variants affecting the gene represented in this entry"}]}},{"commentType":"DISEASE","disease":{"diseaseId":"Cardiomyopathy, dilated, 1G","diseaseAccession":"DI-00215","acronym":"CMD1G","description":"A disorder characterized by ventricular dilation and impaired systolic function, resulting in congestive heart failure and arrhythmia. Patients are at risk of premature death.","diseaseCrossReference":{"database":"MIM","id":"604145"},"evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"11788824"},{"evidenceCode":"ECO:0000269","source":"PubMed","id":"11846417"},{"evidenceCode":"ECO:0000269","source":"PubMed","id":"16465475"}]},"note":{"texts":[{"value":"The disease is caused by variants affecting the gene represented in this entry"}]}},{"commentType":"DISEASE","disease":{"diseaseId":"Tardive tibial muscular dystrophy","diseaseAccession":"DI-02358","acronym":"TMD","description":"Autosomal dominant, late-onset distal myopathy. Muscle weakness and atrophy are usually confined to the anterior compartment of the lower leg, in particular the tibialis anterior muscle. Clinical symptoms usually occur at age 35-45 years or much later.","diseaseCrossReference":{"database":"MIM","id":"600334"},"evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"12145747"},{"evidenceCode":"ECO:0000269","source":"PubMed","id":"12891679"}]},"note":{"texts":[{"value":"The disease is caused by variants affecting the gene represented in this entry"}]}},{"commentType":"DISEASE","disease":{"diseaseId":"Muscular dystrophy, limb-girdle, autosomal recessive 10","diseaseAccession":"DI-00667","acronym":"LGMDR10","description":"An autosomal recessive degenerative myopathy characterized by progressive weakness of the pelvic and shoulder girdle muscles. Severe disability is observed within 20 years of onset.","diseaseCrossReference":{"database":"MIM","id":"608807"},"evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"12145747"}]},"note":{"texts":[{"value":"The disease is caused by variants affecting the gene represented in this entry"}]}},{"commentType":"DISEASE","disease":{"diseaseId":"Congenital myopathy 5 with cardiomyopathy","diseaseAccession":"DI-01514","acronym":"CMYO5","description":"An autosomal recessive, early-onset muscular disorder characterized by dilated cardiomyopathy, delayed motor development with generalized muscle weakness predominantly affecting proximal and distal lower limbs. Skeletal muscle biopsies show minicore-like lesions with mitochondrial depletion and sarcomere disorganization, centralized nuclei, and type 1 fiber predominance. Dystrophic changes become apparent in the second decade. Cardiac muscle biopsies show disruption of myocardial architecture, nuclear hypertrophy, and endomysial fibrosis. Sudden death may occurr due to cardiomyopathy.","diseaseCrossReference":{"database":"MIM","id":"611705"},"evidences":[{"evidenceCode":"ECO:0000269","source":"PubMed","id":"17444505"}]},"note":{"texts":[{"value":"The disease is caused by variants affecting the gene represented in this entry"}]}},{"texts":[{"value":"In some isoforms, after the PEVK repeat region there is a long PEVK duplicated region. On account of this region, it has been very difficult to sequence the whole protein. The length of this region (ranging from 183 to 2174 residues), may be a key elastic element of titin"}],"commentType":"MISCELLANEOUS"},{"texts":[{"evidences":[{"evidenceCode":"ECO:0000305"}],"value":"Belongs to the protein kinase superfamily. CAMK Ser/Thr protein kinase family"}],"commentType":"SIMILARITY"},{"commentType":"SEQUENCE CAUTION","sequenceCautionType":"Miscellaneous discrepancy","sequence":"AAH58824.1","note":"Contaminating sequence. Potential poly-A sequence starting in position 553.","evidences":[{"evidenceCode":"ECO:0000305"}]},{"commentType":"SEQUENCE CAUTION","sequenceCautionType":"Miscellaneous discrepancy","sequence":"AAH70170.1","note":"Contaminating sequence. Potential poly-A sequence starting in position 627.","evidences":[{"evidenceCode":"ECO:0000305"}]},{"commentType":"SEQUENCE CAUTION","sequenceCautionType":"Frameshift","sequence":"CAA62188.1","evidences":[{"evidenceCode":"ECO:0000305"}]},{"commentType":"SEQUENCE CAUTION","sequenceCautionType":"Frameshift","sequence":"CAD12455.1","evidences":[{"evidenceCode":"ECO:0000305"}]},{"commentType":"WEB RESOURCE","resourceName":"Wikipedia","resourceUrl":"https://en.wikipedia.org/wiki/Titin","ftp":false,"note":"Titin entry"}],"features":[{"type":"Chain","location":{"start":{"value":1,"modifier":"EXACT"},"end":{"value":34350,"modifier":"EXACT"}},"description":"Titin","featureId":"PRO_0000239311"},{"type":"Domain","location":{"start":{"value":6,"modifier":"EXACT"},"end":{"value":96,"modifier":"EXACT"}},"description":"Ig-like 1"},{"type":"Domain","location":{"start":{"value":104,"modifier":"EXACT"},"end":{"value":192,"modifier":"EXACT"}},"description":"Ig-like 2"},{"type":"Repeat","location":{"start":{"value":417,"modifier":"EXACT"},"end":{"value":462,"modifier":"EXACT"}},"description":"Z-repeat 1"},{"type":"Repeat","location":{"start":{"value":466,"modifier":"EXACT"},"end":{"value":511,"modifier":"EXACT"}},"description":"Z-repeat 2"},{"type":"Repeat","location":{"start":{"value":512,"modifier":"EXACT"},"end":{"value":554,"modifier":"EXACT"}},"description":"Z-repeat 3"},{"type":"Repeat","location":{"start":{"value":555,"modifier":"EXACT"},"end":{"value":600,"modifier":"EXACT"}},"description":"Z-repeat 4"},{"type":"Repeat","location":{"start":{"value":601,"modifier":"EXACT"},"end":{"value